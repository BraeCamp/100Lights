<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's V8 JIT -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for WASM (FFmpeg.wasm) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for Electron's dynamic library loading -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network access (required for all web content and API calls) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- File access for open/save dialogs -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Microphone for audio recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Camera for video capture (future live session feature) -->
    <key>com.apple.security.device.camera</key>
    <true/>
  </dict>
</plist>
